#!/usr/bin/env bash
# grabit — move files between this (often headless) OPS box and the machine
# you're driving it from, over Tailscale. No SFTP, no cloud; tailnet-encrypted,
# never public (uses `tailscale serve`, not `funnel`).
#
# Default action = PUSH: Taildrop the file(s) to the device you SSH'd in from
# (auto-detected from $SSH_CONNECTION) so they land in that machine's Tailscale
# inbox. Also supports a browser-grab mode and a receive mode.
#
#   grabit FILE...              push file(s) to the machine you're connected from
#   grabit --to DEVICE FILE...  push to a specific tailnet device (name or 100.x IP)
#   grabit --serve PATH...      stage path(s) + expose over tailnet HTTPS; prints URLs
#   grabit --serve-off          tear the serve endpoint down
#   grabit --inbox [DIR]        pull files sent TO this box (default ~/grabit-inbox)
#   grabit --list               list tailnet devices
#   grabit -h | --help
#
# One-time per box (already done on this one): sudo tailscale set --operator=$USER
# so transfers need no sudo. Only ever stages files you name — never exposes the
# directory they live in, so a neighbouring .env can't leak.
set -euo pipefail

SERVE_DIR="${GRABIT_SERVE_DIR:-$HOME/.cache/grabit-serve}"

die(){ echo "grabit: $*" >&2; exit 1; }
command -v tailscale >/dev/null 2>&1 || die "tailscale not found on PATH"

usage(){ awk 'NR>=2{ if(/^#/){sub(/^# ?/,"");print} else exit }' "$0"; }

self_dns(){ tailscale status --json 2>/dev/null \
  | python3 -c 'import sys,json;print(json.load(sys.stdin)["Self"]["DNSName"].rstrip("."))'; }

# Map a tailnet IP -> device name from `tailscale status`.
ip_to_device(){ tailscale status 2>/dev/null | awk -v ip="$1" '$1==ip{print $2; exit}'; }

# Resolve the default push target: the device you're connected from, else the
# single active directly-connected remote device.
default_target(){
  local cip dev
  if [ -n "${SSH_CONNECTION:-}" ]; then
    cip="${SSH_CONNECTION%% *}"                       # first field = client IP
    dev="$(ip_to_device "$cip")"
    [ -n "$dev" ] && { echo "$dev"; return 0; }
  fi
  dev="$(tailscale status 2>/dev/null | awk '/active; direct/{print $2; n++} END{exit (n==1)?0:1}')" \
    && [ -n "$dev" ] && { echo "$dev"; return 0; }
  return 1
}

push(){
  local target="$1"; shift
  [ "$#" -gt 0 ] || die "no files to push"
  local f; for f in "$@"; do [ -e "$f" ] || die "no such file: $f"; done
  echo "grabit: pushing to '$target' via Taildrop"
  local failed=()
  for f in "$@"; do
    if tailscale file cp "$f" "$target:"; then
      echo "  sent: $(basename "$f")"
    else
      echo "  FAILED: $(basename "$f")" >&2
      failed+=("$(basename "$f")")
    fi
  done
  if [ "${#failed[@]}" -eq 0 ]; then
    echo "grabit: on '$target', the file lands in the Tailscale receive folder (Downloads on Windows, auto-saved; else run 'tailscale file get DIR')."
  else
    die "${#failed[@]} of $# file(s) failed to send to '$target': ${failed[*]}"
  fi
}

serve(){
  [ "$#" -gt 0 ] || die "nothing to serve"
  rm -rf "$SERVE_DIR"; mkdir -p "$SERVE_DIR"
  local p; for p in "$@"; do [ -e "$p" ] || die "no such path: $p"; cp -r "$p" "$SERVE_DIR/"; done
  # Serving a path is privileged even for an operator; needs (passwordless) sudo.
  # Taildrop (the default push) does NOT need this — prefer it where sudo is absent.
  sudo tailscale serve --bg "$SERVE_DIR" >/dev/null 2>&1 \
    || die "tailscale serve failed (needs sudo + tailnet HTTPS enabled; just use a plain 'grabit FILE' push instead)"
  local url; url="https://$(self_dns)/"
  echo "grabit: serving over the tailnet (HTTPS, not public). Open in your browser:"
  ( cd "$SERVE_DIR" && for f in *; do echo "  ${url}${f}"; done )
  echo "grabit: tear down when done with -> grabit --serve-off"
}

serve_off(){ sudo tailscale serve reset >/dev/null 2>&1 || true; rm -rf "$SERVE_DIR"; echo "grabit: serve torn down."; }

inbox(){
  local dir="${1:-$HOME/grabit-inbox}"; mkdir -p "$dir"
  tailscale file get "$dir" && echo "grabit: pulled inbox -> $dir" && ls -la "$dir"
}

main(){
  case "${1:-}" in
    -h|--help|"")  usage; exit 0;;
    --list)        tailscale status; exit 0;;
    --serve)       shift; serve "$@";;
    --serve-off)   serve_off;;
    --inbox)       shift; inbox "${1:-}";;
    --to)          shift; [ "$#" -ge 2 ] || die "usage: grabit --to DEVICE FILE..."
                   local t="$1"; shift; push "$t" "$@";;
    --*)           die "unknown option: $1 (try -h)";;
    *)             local t; t="$(default_target)" \
                     || die "couldn't auto-detect a target device; use: grabit --to DEVICE FILE..."
                   push "$t" "$@";;
  esac
}
main "$@"
